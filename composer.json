{
  "name": "k2gl/rekor-client",
  "description": "A PSR-18 client for the Rekor v2 transparency log — submit entries and read checkpoints in PHP.",
  "homepage": "https://github.com/k2gl/rekor-client",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "rekor",
    "sigstore",
    "transparency-log",
    "tlog",
    "hashedrekord",
    "checkpoint",
    "supply-chain",
    "psr-18"
  ],
  "authors": [
    {
      "name": "Nick Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/rekor-client/issues",
    "source": "https://github.com/k2gl/rekor-client"
  },
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1|^2.0",
    "k2gl/sigstore-bundle": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11|^12",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "~1.20.0",
    "k2gl/phpunit-fluent-assertions": "^12",
    "nyholm/psr7": "^1.8"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\RekorClient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\RekorClient\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "pint --test",
    "cs-fix": "pint",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
